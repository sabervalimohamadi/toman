{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "lib": ["ES2020"],
    "types": ["node"],
    "typeRoots": [
      "./node_modules/@nativescript/types-android",
      "./node_modules/@nativescript/types-ios",
      "./node_modules/@types"
    ],
    "paths": {
      "~/*": ["./app/*"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.vue", "nativescript.config.ts"],
  "exclude": ["node_modules", "platforms", "hooks"]
}
